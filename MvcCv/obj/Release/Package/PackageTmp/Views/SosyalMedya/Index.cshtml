@using MvcCv.Models.Entity
@model List<TblSosyalMedya>
@{
	ViewBag.Title = "Index";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<style>
	.center {
		display: flex;
		justify-content: center;
	}

	.button {
		background-color: #4CAF50; /* Green */
		border: none;
		color: white;
		padding: 10px 20px;
		border-radius: 5px;
		text-align: center;
		text-decoration: none;
		display: inline-block;
		font-size: 16px;
		cursor: pointer;
		margin: 4px 4px;
		transition-duration: 0.4s;
		cursor: pointer;
	}

	.button1 {
		background-color: white;
		color: #F08080;
		border: 1px solid #F08080;
	}

		.button1:hover {
			background-color: #F08080;
			color: white;
		}
</style>
<!DOCTYPE html>
<html>
<body class="hold-transition sidebar-mini">
	<div class="wrapper">
		<!-- Navbar -->
		<!-- Main content -->
		<section class="content">
			<div class="container-fluid">
				<div class="row justify-content-center">
					<div class="col-lg-8">
						<div class="card card-warning card-outline" style="border-color: forestgreen;">
							<div class="card-header center">
								<h3 class="card-title text-black-450 text-xl" style="color:forestgreen">HAKKIMDA İKON LİSTESİ</h3>
							</div>
							<!-- /.card-header -->
							<div class="card-body">
								<div class="table-responsive">
									<table class="table table-bordered">

										<thead>
											<tr>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: forestgreen; color:forestgreen">ID</th>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: forestgreen; color: forestgreen">AD</th>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: forestgreen; color: forestgreen">Düzenle</th>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: forestgreen; color: forestgreen">Sil</th>
											</tr>
										</thead>
										<tbody>
											@foreach (var item in Model)
											{
												<tr>
													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: forestgreen; color: forestgreen">@item.ID</td>
													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: forestgreen; color: forestgreen">@item.Ad</td>
													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: forestgreen; color: forestgreen">
														<a href="/SosyalMedya/SayfaGetir/@item.ID" class="btn btn-outline-success btn-sm" style="width: 100%; height: 50%; display: flex; align-items: center; justify-content: center;">
															<i class="fas fa-pencil-alt"></i>&nbsp;Güncelle

														</a>
													</td>



													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: forestgreen; color: forestgreen">
														<a href="/SosyalMedya/Sil/@item.ID" class="btn btn-outline-success btn-sm" style="width: 100%; height: 50%; display: flex; align-items: center; justify-content: center;">
															<i class="fas fa-trash-alt"></i>&nbsp;Silmek

														</a>
													</td>

												</tr>
											}
										</tbody>
									</table>
									<div class="btn-container" style="text-align: center;">

										<button class="btn btn-outline-success btn-group-lg" data-toggle="modal" data-target="#Modal1">Yeni İkon Ekle</button>
									</div>
								</div>
							</div>
						</div>
						<!-- /.card -->
					</div>
				</div>
			</div><!-- /.container-fluid -->
		</section>
		<!-- /.content -->
	</div>
</body>
</html>


<!-- Modal -->

<div class="modal" id="Modal1">

	<br /> <br />

	<div class="modal-dialog modal-xl" style="margin-right: 250px;">
		<div class="modal-content">



			<div class="modal-header bg-gradient-success text-white center">

				<h2 class="modal-title">Yeni İkon ve Link Ekleme</h2>
			</div>
			<form method="post" action="/SosyalMedya/Ekle">
				<div class="modal-body">
					<div class="mb-3">
						<label for="iconName" class="form-label center">İkon Adı</label>
						<input type="text" name="Ad" class="form-control" id="iconName" />
					</div>
					<div class="mb-3">
						<label for="pageLink" class="form-label center">Sayfa Linki</label>
						<input type="text" name="Link" class="form-control" id="pageLink" />
					</div>
					<div class="mb-3">
						<label for="iconCode" class="form-label center">İkon Kodu</label>
						<input type="text" name="ikon" class="form-control" id="iconCode" />
					</div>
				</div>
				<div class="modal-footer center">
					<button type="submit" class="btn btn-outline-success btn-group-lg">Ekle</button>
				</div>
			</form>
		</div>
	</div>
</div>
