@model MvcCv.Models.Entity.TblSosyalMedya
@{
	ViewBag.Title = "SayfaGetir";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<style>
	.center {
		display: flex;
		justify-content: center;
	}

	.card-title {
		font-size: 24px; /* Dilediğiniz büyüklük */
		color: #333; /* Dilediğiniz renk */
	}

	.card {
		border-radius: 10px; /* Kenar yumuşatma */
		box-shadow: 0px 2px 6px rgba(0, 0, 0, 0.1); /* Hafif gölge */
	}

	.form-group {
		margin-bottom: 15px;
	}

	.form-label {
		font-weight: bold;
		color: #555;
	}

	.form-control {
		border: 1px solid #ccc;
		border-radius: 5px;
		padding: 8px;
	}

	.btn-outline-warning {
		background-color: #ffc107; /* Dilediğiniz renk */
		color: white;
		border: none;
		padding: 10px 20px;
		border-radius: 5px;
		cursor: pointer;
	}

		.btn-outline-warning:hover {
			background-color: #ff9800; /* Hover rengi */
		}
</style>


<section class="content">
	<div class="container-fluid">
		<div class="row justify-content-center">
			<div class="col-lg-5">
				<div class="card card-success card-outline">
					<div class="card-header center">
						<h3 class="card-title text-black-450 text-xl" style="color:forestgreen"> İkon Güncelleme Sayfası</h3>
					</div>
					<div class="card-body">
						<form method="post">
							<div class="form-group">
								<label class="form-label" style="color:forestgreen">İKON ADI</label>
								@Html.TextBoxFor(x => x.Ad, new { @class = "form-control", style = "color: forestgreen;" })
								<br />
								<label class="form-label" style="color:forestgreen">İKON KODU</label>
								@Html.TextBoxFor(x => x.ikon, new { @class = "form-control", style = "color: forestgreen;" })
								<br />
								<label class="form-label" style="color:forestgreen">SİTE LİNKİ</label>
								@Html.TextBoxFor(x => x.Link, new { @class = "form-control", style = "color: forestgreen;" })
							</div>
							<div class="btn-container" style="text-align: center;">
								<button class="btn btn-outline-success btn-group-lg">Güncelle</button>
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>