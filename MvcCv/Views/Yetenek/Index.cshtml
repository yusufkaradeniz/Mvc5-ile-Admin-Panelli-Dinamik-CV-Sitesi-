@using MvcCv.Models.Entity
@model List<TblYeteneklerim>
@{
	ViewBag.Title = "Index";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@{ string renk = ""; }
@{ string labelrenk = ""; }
<br />
<style>
	.center {
		display: flex;
		justify-content: center;
	}
	.button {
		background-color: #4CAF50; /* Green */
		border: none;
		color: white;
		padding: 10px 20px;
		border-radius: 5px;
		text-align: center;
		text-decoration: none;
		display: inline-block;
		font-size: 16px;
		cursor: pointer;
		margin: 4px 4px;
		transition-duration: 0.4s;
		cursor: pointer;
	}
	.button1 {
		background-color: white;
		color: #F08080;
		border: 1px solid #F08080;
	}
		.button1:hover {
			background-color: #F08080;
			color: white;
		}


</style>
<!DOCTYPE html>
<html>
<body class="hold-transition sidebar-mini">
	<div class="wrapper">
		<!-- Navbar -->
		<!-- Main content -->
		<section class="content">
			<div class="container-fluid">
				<div class="row justify-content-center">
					<div class="col-lg-8">
						<div class="card card-warning card-outline" style="border-color: #F08080;">
							<div class="card-header center">
								<h3 class="card-title text-black-450 text-xl">YETENEK LİSTESİ</h3>
							</div>
							<!-- /.card-header -->
							<div class="card-body">
								<div class="table-responsive">
									<table class="table table-bordered">

										<thead>
											<tr>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;">ID</th>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;">Yetenek</th>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;">Derece</th>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080; ">Oran</th>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080; ">Düzenle</th>
												<th style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080; ">Sil</th>
											</tr>
										</thead>
										<tbody>
											@foreach (var item in Model)
											{
												if (item.Oran >= 0 && item.Oran <= 50)
												{
													renk = "progress-bar bg-danger";
													labelrenk = "progress-bar bg-danger";
												}
												if (item.Oran >= 51 && item.Oran <= 70)
												{
													renk = "progress-bar bg-warning";
													labelrenk = "progress-bar bg-warning";
												}
												if (item.Oran >= 71 && item.Oran <= 84)
												{
													renk = "progress-bar bg-primary";
													labelrenk = "progress-bar bg-primary";
												}
												if (item.Oran >= 85 && item.Oran <= 100)
												{
													renk = "progress-bar bg-success";
													labelrenk = "progress-bar bg-success";
												}
												<tr>
													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;" >@item.ID</td>
													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;">@item.Yetenek</td>
													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;">
														<div class="progress progress-xs ">
															<div class="@renk" style="width: @item.Oran%"></div>
														</div>
													</td>
													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;"><span class="@labelrenk">@item.Oran%</span></td>

													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;">
														<a href="/Yetenek/YetenekDuzenle/@item.ID" class="btn btn-warning btn-sm" style="width: 100%; height: 50%; display: flex; align-items: center; justify-content: center;">
															<i class="fas fa-pencil-alt"></i>&nbsp;Güncelle

														</a>
													</td>



													<td style="text-align: center; padding: 4px; vertical-align: middle; height: 50%; border-color: #F08080;">
														<a href="/Yetenek/YetenekSil/@item.ID" class="btn btn-danger btn-sm" style="width: 100%; height: 50%; display: flex; align-items: center; justify-content: center;">
															<i class="fas fa-trash-alt"></i>&nbsp;Silmek

														</a>
													</td>




												</tr>
											}
										</tbody>
									</table>
									<div class="btn-container" style="text-align: center;">
										<a href="/Yetenek/YeniYetenek/" class="button button1 ">Yeni Yetenek Ekle</a>
									</div>
								</div>
							</div>
						</div>
						<!-- /.card -->
					</div>
				</div>
			</div><!-- /.container-fluid -->
		</section>
		<!-- /.content -->
	</div>
</body>
</html>