@{
	ViewBag.Title = "DeneyimEkle";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<style>
	.center {
		display: flex;
		justify-content: center;
	}
</style>
<section class="content">
	<div class="container-fluid">
		<div class="row justify-content-center">
			<div class="col-lg-8">
				<div class="card card-success card-outline">
					<div class="card-header center">
						<h3 class="card-title text-black-450 text-xl">Yeni Deneyim Ekleme Sayfası</h3>
					</div>
					<div class="card-body">
						<div class="form-container">
							<form method="post">
								<div class="form-group">
									<label class="form-label" for="Baslik">Şirket Adı</label>
									<input type="text" id="Baslik" name="Baslik" class="form-control" placeholder="Şirket Adı" />
								</div>
								<div class="form-group">
									<label class="form-label" for="AltBaslik">Çalışma Pozisyonu</label>
									<input type="text" id="AltBaslik" name="AltBaslik" class="form-control" placeholder="Çalışma Pozisyonu" />
								</div>
								<div class="form-group">
									<label class="form-label" for="Tarih">Çalışma Tarihi</label>
									<input type="text" id="Tarih" name="Tarih" class="form-control" placeholder="Çalışma Tarihi" />
								</div>
								<div class="form-group">
									<label class="form-label" for="Aciklama">Açıklama</label>
									<textarea id="Aciklama" name="Aciklama" class="form-control" rows="6" style="resize: none;" placeholder="Açıklamanızı giriniz"></textarea>
								</div>
								<div class="btn-container" style="text-align: center;">
									<button class="btn btn-success btn-group-lg">Kaydet</button>
								</div>
							</form>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
