@model MvcCv.Models.Entity.TblDeneyimlerim
@{
	ViewBag.Title = "DeneyimGetir";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<style>
	.center {
		display: flex;
		justify-content: center;
	}
</style>

<section class="content">
	<div class="container-fluid">
		<div class="row justify-content-center">
			<div class="col-lg-8">
				<div class="card card-warning card-outline">
					<div class="card-header center">
						<h3 class="card-title text-black-450 text-xl">Deneyim Güncelleme Sayfası</h3>
					</div>
					<div class="card-body">
						<div class="form-container">
							<form method="post">
								<div class="form-group">
									<label class="form-label">Deneyim ID</label>
									@Html.TextBoxFor(x => x.ID, new { @class = "form-control" })
								</div>
								<div class="form-group">
									<label class="form-label">Şirket Adı</label>
									@Html.TextBoxFor(x => x.Baslik, new { @class = "form-control" })
								</div>
								<div class="form-group">
									<label class="form-label">Çalışma Pozisyonu</label>
									@Html.TextBoxFor(x => x.AltBaslik, new { @class = "form-control" })
								</div>
								<div class="form-group">
									<label class="form-label">Çalışma Tarihi</label>
									@Html.TextBoxFor(x => x.Tarih, new { @class = "form-control" })
								</div>
								<div class="form-group">
									<label class="form-label">Açıklamanızı giriniz</label>
									@Html.TextAreaFor(x => x.Aciklama, new { @class = "form-control", @rows = "10", @style = "resize: none;" })
								</div>
								<div class="btn-container" style="text-align: center;">
									<button class="btn btn-warning btn-group-lg">Güncelle</button>
								</div>
							</form>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
