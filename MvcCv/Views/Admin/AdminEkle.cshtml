
@{
	ViewBag.Title = "AdminEkle";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<style>
	.center {
		display: flex;
		justify-content: center;
	}
</style>
<section class="content">
	<div class="container-fluid">
		<div class="row justify-content-center">
			<div class="col-lg-8">
				<div class="card card-success card-outline">
					<div class="card-header center">
						<h3 class="card-title text-black-450 text-xl">Yeni Kullanıcı Ekleme Sayfası</h3>
					</div>
					<div class="card-body">
						<div class="form-container">
							<form method="post">
								<div class="form-group">
									<label class="form-label" for="KullaniciAdi">Kullanıcı Adı</label>
									<input type="text" id="KullaniciAdi" name="KullaniciAdi" class="form-control" placeholder="Kullanıcı Adı" />
								</div>
								<div class="form-group">
									<label class="form-label" for="Sifre">Şifre</label>
									<input type="text" id="Sifre" name="Sifre" class="form-control" placeholder="Sifre" />
								</div>
								<div class="btn-container" style="text-align: center;">
									<button class="btn btn-success btn-group-lg">Kaydet</button>
								</div>
							</form>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
