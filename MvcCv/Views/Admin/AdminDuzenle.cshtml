@model MvcCv.Models.Entity.TblAdmin
@{
	ViewBag.Title = "AdminDuzenle";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<br />
<style>
	.center {
		display: flex;
		justify-content: center;
	}
</style>

<section class="content">
	<div class="container-fluid">
		<div class="row justify-content-center">
			<div class="col-lg-8">
				<div class="card card-warning card-outline">
					<div class="card-header center">
						<h3 class="card-title text-black-450 text-xl">ADMİN Güncelleme Sayfası</h3>
					</div>
					<div class="card-body">
						<div class="form-container">
							<form method="post">
								<div class="form-group">
									<label class="form-label">Kullanıcı Adı</label>
									@Html.TextBoxFor(x => x.KullaniciAdi, new { @class = "form-control" })
								</div>
								<div class="form-group">
									<label class="form-label">Şifre</label>
									@Html.TextBoxFor(x => x.Sifre, new { @class = "form-control" })
								</div>
								<div class="btn-container" style="text-align: center;">
									<button class="btn btn-warning btn-group-lg">Güncelle</button>
								</div>
							</form>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>


