@using MvcCv.Models.Entity
@model List<Tbliletisim>
@{
	ViewBag.Title = "Index";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
	.message-divider {
		
		margin: 4px 4%; /* Çizgi üzerinde ve altında boşluk */
	}

	.bold-black {
		font-weight: bold;
		color: black;
	}
</style>
<!DOCTYPE html>
<html>
<body class="hold-transition sidebar-mini">
	<section class="content">
		<div class="container-fluid">
			<div class="row">

				<!-- /.col -->
				<div class="col-md-12">
					<div class="card">
					<!-- /.card-header -->
						<div class="card-body">
								<div class="tab-pane" id="timeline">
									<!-- The timeline -->
									<div class="timeline timeline-inverse">
										@foreach(var item in Model) {
										<!-- timeline time label -->
										<div class="time-label">
											<span class="bg-gradient-white">
												<i class="far fa-calendar"></i>

												@(((DateTime)item.Tarih).ToString("dd-MMM-yyyy"));


											</span>
										</div>
										<div>
											<i class="fas fa-comments bg-warning"></i>
											<div class="timeline-item">
												<span class="time"><i class="far fa-clock"></i> @item.Mail</span>
												<h3 class="timeline-header"><a href="#">@item.Adsoyad</a> <br /> <br /> 
										 <span class="bold-black">@item.Konu</span>
												</h3> 
												<div class="message-divider timeline-body">
													@item.Mesaj
												</div>
											</div>
										</div>	
										}
									</div>
								</div>
							</div>
							<!-- /.tab-content -->
						</div><!-- /.card-body -->
					</div>
					<!-- /.nav-tabs-custom -->
				</div>
				<!-- /.col -->
			</div>
	</section>
</body>
</html>